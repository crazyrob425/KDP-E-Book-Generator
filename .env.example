# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Required: Google Gemini API key (https://aistudio.google.com/app/apikey)
VITE_GOOGLE_API_KEY=your_google_gemini_api_key_here

# Optional: Tavily API key for live web research (free tier at tavily.com)
VITE_TAVILY_API_KEY=

# Optional: OpenAI-compatible endpoint (Ollama, LM Studio, Groq, OpenRouter, etc.)
VITE_OPENAI_BASE_URL=
VITE_OPENAI_API_KEY=

# Required only for KDP automation backend
KDP_EMAIL=your-kdp-email@example.com
KDP_PASSWORD=your-kdp-password
